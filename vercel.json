{
  "version": 2,
  "installCommand": "cd server && npm install",
  "buildCommand": "cd server && npx prisma generate",
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node" },
    { "src": "frontend/**/*", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "api/index.js" },
    { "src": "/(.*)", "dest": "frontend/$1" }
  ]
}
