# === Supabase (PostgreSQL) — recomendado ===
# Dashboard: Project Settings → Database → Connection string → URI
# Usa Transaction pooler (6543) para DATABASE_URL y Session/Direct (5432) para DIRECT_URL

# Opción A — conexión directa (recomendada para desarrollo local)
DATABASE_URL="postgresql://postgres:TU_PASSWORD@db.idjpuerqrszasxgohexv.supabase.co:5432/postgres?schema=sabor_ecuatoriano"
DIRECT_URL="postgresql://postgres:TU_PASSWORD@db.idjpuerqrszasxgohexv.supabase.co:5432/postgres?schema=sabor_ecuatoriano"

# Opción B — pooler (si la directa falla)
# DATABASE_URL="postgresql://postgres.idjpuerqrszasxgohexv:TU_PASSWORD@aws-0-us-east-2.pooler.supabase.com:6543/postgres?pgbouncer=true&schema=sabor_ecuatoriano"
# DIRECT_URL="postgresql://postgres.idjpuerqrszasxgohexv:TU_PASSWORD@aws-0-us-east-2.pooler.supabase.com:5432/postgres?schema=sabor_ecuatoriano"

# === Alternativa: SQL Server local ===
# DATABASE_URL="sqlserver://localhost:1433;database=SaborEcuatoriano;user=sa;password=TU_PASSWORD;encrypt=true;trustServerCertificate=true"
# (Si usas SQL Server, cambia provider en prisma/schema.prisma a sqlserver y quita DIRECT_URL)

PORT=3000
NODE_ENV=development
JWT_SECRET=cambia_este_secreto_por_uno_seguro_de_al_menos_32_caracteres
JWT_EXPIRES_IN=8h
CORS_ORIGIN=http://localhost:5500
