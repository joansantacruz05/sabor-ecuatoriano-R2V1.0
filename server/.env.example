# === Supabase (PostgreSQL) — conexión vía pooler compartido ===
# Obtén estas URIs desde: Supabase Dashboard → Connect → ORM
# DATABASE_URL usa el transaction pooler (6543) — ideal para serverless
# DIRECT_URL usa el session pooler (5432) — usado por Prisma para migraciones

DATABASE_URL="postgresql://postgres.TU_PROJECT_REF:TU_PASSWORD@aws-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.TU_PROJECT_REF:TU_PASSWORD@aws-REGION.pooler.supabase.com:5432/postgres"

PORT=3000
NODE_ENV=development
JWT_SECRET=cambia_este_secreto_por_uno_seguro_de_al_menos_32_caracteres
JWT_EXPIRES_IN=8h
CORS_ORIGIN=http://localhost:5500
