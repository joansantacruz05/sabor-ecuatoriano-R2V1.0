generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["sabor_ecuatoriano"]
}

model Rol {
  id       Int       @id @default(autoincrement())
  nombre   String    @unique @db.VarChar(20)
  usuarios Usuario[]

  @@map("rol")
  @@schema("sabor_ecuatoriano")
}

model Categoria {
  id        Int        @id @default(autoincrement())
  nombre    String     @unique @db.VarChar(50)
  productos Producto[]

  @@map("categoria")
  @@schema("sabor_ecuatoriano")
}

model Usuario {
  id                Int       @id @default(autoincrement())
  username          String    @unique @db.VarChar(50)
  email             String    @unique @db.VarChar(100)
  passwordHash      String    @map("password_hash") @db.VarChar(255)
  rolId             Int       @default(2) @map("rol_id")
  rol               Rol       @relation(fields: [rolId], references: [id])
  resetToken        String?   @unique @map("reset_token") @db.VarChar(255)
  resetTokenExpiry  DateTime? @map("reset_token_expiry")
  createdAt         DateTime  @default(now()) @map("created_at")
  pedidos           Pedido[]

  @@map("usuario")
  @@schema("sabor_ecuatoriano")
}

model Producto {
  id          Int             @id @default(autoincrement())
  nombre      String          @db.VarChar(100)
  precio      Float
  stock       Int             @default(0)
  categoriaId Int?            @map("categoria_id")
  categoria   Categoria?      @relation(fields: [categoriaId], references: [id])
  descripcion String?         @db.VarChar(500)
  imagen      String?         @db.VarChar(500)
  createdAt   DateTime        @default(now()) @map("created_at")
  detalles    PedidoDetalle[]

  @@map("producto")
  @@schema("sabor_ecuatoriano")
}

model Pedido {
  id        Int             @id @default(autoincrement())
  userId    Int             @map("user_id")
  total     Float
  createdAt DateTime        @default(now()) @map("created_at")
  usuario   Usuario         @relation(fields: [userId], references: [id])
  detalles  PedidoDetalle[]

  @@map("pedido")
  @@schema("sabor_ecuatoriano")
}

model PedidoDetalle {
  id             Int      @id @default(autoincrement())
  pedidoId       Int      @map("pedido_id")
  productoId     Int      @map("producto_id")
  cantidad       Int
  precioUnitario Float    @map("precio_unitario")
  pedido         Pedido   @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  producto       Producto @relation(fields: [productoId], references: [id])

  @@map("pedido_detalle")
  @@schema("sabor_ecuatoriano")
}
