# Copia este archivo como server/.env y ajusta los valores
# Las URIs reales se obtienen desde Supabase Dashboard → Connect → ORM

DATABASE_URL="postgresql://postgres.TU_PROJECT_REF:TU_PASSWORD@aws-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.TU_PROJECT_REF:TU_PASSWORD@aws-REGION.pooler.supabase.com:5432/postgres"

PORT=3000
NODE_ENV=development

# JWT (usa un secreto largo y aleatorio en producción)
JWT_SECRET=cambia_este_secreto_por_uno_seguro_de_al_menos_32_caracteres
JWT_EXPIRES_IN=8h

# CORS: origen permitido del frontend (NO usar * en producción)
CORS_ORIGIN=http://localhost:3000
