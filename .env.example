# Copia este archivo como server/.env y ajusta los valores

# SQL Server (Prisma)
# Ejemplo local con SQL Server Express:
DATABASE_URL="sqlserver://localhost:1433;database=SaborEcuatoriano;user=sa;password=TU_PASSWORD;encrypt=true;trustServerCertificate=true"

# Servidor
PORT=3000
NODE_ENV=development

# JWT (usa un secreto largo y aleatorio en producción)
JWT_SECRET=cambia_este_secreto_por_uno_seguro_de_al_menos_32_caracteres
JWT_EXPIRES_IN=8h

# CORS: origen permitido del frontend (NO usar * en producción)
CORS_ORIGIN=http://localhost:5500
